{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Principal": "*",
        "Action": [
          "secretsmanager:Describe*",
          "secretsmanager:Get*",
          "secretsmanager:List*"
        ],
        "Resource": "*",
        "Condition": {
          "ArnLike": {
            "aws:PrincipalARN": ${service_roles}
          }
        }
      }
    ]
  }
